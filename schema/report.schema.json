{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Report",
  "description": "Full report data model: only bounded aggregates, never a per-object Vec.",
  "type": "object",
  "properties": {
    "generated": {
      "type": "string"
    },
    "leaks": {
      "$ref": "#/$defs/LeakSuspects"
    },
    "overview": {
      "$ref": "#/$defs/SystemOverview"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "top": {
      "$ref": "#/$defs/TopConsumers"
    }
  },
  "required": [
    "schema_version",
    "generated",
    "overview",
    "leaks",
    "top"
  ],
  "$defs": {
    "ClassRow": {
      "description": "One row of \"Biggest Classes\".",
      "type": "object",
      "properties": {
        "instances": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "pretty_class": {
          "type": "string"
        },
        "retained": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "pretty_class",
        "instances",
        "retained"
      ]
    },
    "HistRow": {
      "description": "One row of the System-Overview class histogram (full, one row per class).",
      "type": "object",
      "properties": {
        "instances": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "pretty_class": {
          "type": "string"
        },
        "retained": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "shallow": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "pretty_class",
        "instances",
        "shallow",
        "retained"
      ]
    },
    "LeakSuspects": {
      "description": "Aggregates for the \"Leak Suspects\" section.",
      "type": "object",
      "properties": {
        "suspects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Suspect"
          }
        },
        "total_shallow": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "total_shallow",
        "suspects"
      ]
    },
    "ObjRow": {
      "description": "One row of \"Biggest Objects\".",
      "type": "object",
      "properties": {
        "display_class": {
          "type": "string"
        },
        "obj_index_1based": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "pct_bp": {
          "description": "Retained share of total reachable shallow heap, in integer basis\npoints (bp = round(retained / total_shallow * 10000)). Deterministic\ninteger for JSON output; the Markdown renderer uses `pct` instead.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "retained": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "shallow": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "obj_index_1based",
        "display_class",
        "shallow",
        "retained",
        "pct_bp"
      ]
    },
    "PackageNode": {
      "description": "One node of the pruned package tree (MAT PackageTreeResult parity).\nTotals are CUMULATIVE over all top-level dominators in this node's subtree.",
      "type": "object",
      "properties": {
        "children": {
          "description": "Children sorted retained-desc, tie-broken by name-asc.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PackageNode"
          }
        },
        "name": {
          "description": "This segment's name (e.g. \"util\"); the root node's name is \"\".",
          "type": "string"
        },
        "retained_heap": {
          "description": "Cumulative retained heap (sum over the top-level dominators under this node).",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "shallow_heap": {
          "description": "Sum of shallow heap of the top-level dominators under this node.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "top_dominator_count": {
          "description": "Number of top-level dominators under this node (MAT \"# Objects\").",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "name",
        "top_dominator_count",
        "shallow_heap",
        "retained_heap",
        "children"
      ]
    },
    "PathStep": {
      "description": "One step of a single-suspect accumulation path.",
      "type": "object",
      "properties": {
        "depth": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "display_class": {
          "type": "string"
        },
        "obj_index_1based": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "retained": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "depth",
        "obj_index_1based",
        "display_class",
        "retained"
      ]
    },
    "Suspect": {
      "description": "One leak suspect (single large object or class group).",
      "type": "object",
      "properties": {
        "instance_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "is_single": {
          "type": "boolean"
        },
        "path": {
          "description": "Non-empty only for single suspects.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PathStep"
          }
        },
        "pretty_class": {
          "type": "string"
        },
        "retained": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "shallow": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "is_single",
        "pretty_class",
        "instance_count",
        "retained",
        "shallow",
        "path"
      ]
    },
    "SystemOverview": {
      "description": "Aggregates for the \"System Overview\" section.",
      "type": "object",
      "properties": {
        "classes_loaded": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "compressed_oops": {
          "description": "Whether the JVM used compressed ordinary object pointers: true when\nreferences are narrower than identifiers (8-byte id, 4-byte ref). None\nwhen undeterminable. Not applicable (false) for 32-bit dumps.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "dump_creation": {
          "description": "Dump creation time in millis since Unix epoch (HPROF header base\ntimestamp). None when the header timestamp is absent/zero.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "file_path": {
          "description": "Full path the dump was opened from (superset of `source_name`).",
          "type": "string"
        },
        "file_size": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "format": {
          "type": "string"
        },
        "gc_roots": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "histogram": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HistRow"
          }
        },
        "histogram_truncated_to": {
          "description": "Number of histogram rows the full histogram was capped to, or None when\nthe histogram is complete (never truncated). Always None today.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "identifier_size_bits": {
          "description": "HPROF identifier size in BITS (id_size bytes * 8: 32 or 64).",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "source_name": {
          "type": "string"
        },
        "total_objects": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "total_shallow": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "unreachable_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "unreachable_shallow": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "source_name",
        "file_path",
        "format",
        "file_size",
        "identifier_size_bits",
        "total_objects",
        "total_shallow",
        "gc_roots",
        "classes_loaded",
        "unreachable_count",
        "unreachable_shallow",
        "histogram"
      ]
    },
    "TopConsumers": {
      "description": "Aggregates for the \"Top Consumers\" section.",
      "type": "object",
      "properties": {
        "biggest_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ClassRow"
          }
        },
        "biggest_objects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ObjRow"
          }
        },
        "biggest_packages": {
          "description": "Root of the pruned package tree (root name = \"\").",
          "$ref": "#/$defs/PackageNode"
        },
        "threshold_bp": {
          "description": "MAT 1%-of-total pruning threshold in basis points (100 bp = 1%).",
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "biggest_objects",
        "biggest_classes",
        "threshold_bp",
        "biggest_packages"
      ]
    }
  }
}
